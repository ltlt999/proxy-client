<ui:FluentWindow x:Class="ProxyClient.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="设置" Width="520" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Style="{StaticResource IconTile}" Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                <Path Data="M18,10 L20,16 L26,17 L21,21 L22,27 L18,24 L14,27 L15,21 L10,17 L16,16 Z"
                      Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round"
                      Width="26" Height="26" Stretch="Uniform"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                <TextBlock Text="调整 ProxyClient 的行为" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="启动与运行" Style="{StaticResource SectionTitle}"/>

                <!-- iOS grouped settings card -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="18,6">
                    <StackPanel>
                        <Grid Margin="0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="开机自动启动" FontWeight="SemiBold" FontSize="13.5"/>
                                <TextBlock Text="系统登录时自动启动并最小化到托盘" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" x:Name="AutoStartChk" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,0"/>

                        <Grid Margin="0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="启动时最小化到托盘" FontWeight="SemiBold" FontSize="13.5"/>
                                <TextBlock Text="打开程序时不显示主窗口" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" x:Name="MinimizeOnStartChk" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderBrush}"/>

                        <Grid Margin="0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="关闭按钮最小化到托盘" FontWeight="SemiBold" FontSize="13.5"/>
                                <TextBlock Text="点击窗口 ✕ 时最小化而非退出" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" x:Name="MinimizeOnCloseChk" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderBrush}"/>

                        <Grid Margin="0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="启动后自动连接" FontWeight="SemiBold" FontSize="13.5"/>
                                <TextBlock Text="程序启动时若有活动节点则自动连接" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" x:Name="AutoStartCoreChk" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                Background="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Top">
                            <TextBlock Text="i" FontSize="13" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Georgia"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="开机自启通过注册表 Run 项实现，路径 HKCU\…\Run，可在此随时关闭或手动在系统设置中移除。"
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource AccentSoftFgBrush}" LineHeight="19"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Width="112" Height="36" Margin="0,0,10,0" IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource AccentButton}">确定</Button>
            <Button Width="112" Height="36" IsCancel="True" Style="{StaticResource SecondaryButton}">取消</Button>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
