<Window x:Class="ProxyClient.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Grid Width="36" Height="36" Margin="0,0,12,0">
                <Ellipse Width="36" Height="36" Fill="{StaticResource AccentSoftBrush}"/>
                <Path Data="M18,10 L20,16 L26,17 L21,21 L22,27 L18,24 L14,27 L15,21 L10,17 L16,16 Z"
                      Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8" StrokeLineJoin="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                <TextBlock Text="调整 ProxyClient 的行为" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="启动与运行" Style="{StaticResource SectionTitle}"/>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="开机自动启动" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="系统登录时自动启动并最小化到托盘" FontSize="12"
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" x:Name="AutoStartChk" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启动时最小化到托盘" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="打开程序时不显示主窗口" FontSize="12"
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" x:Name="MinimizeOnStartChk" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="关闭按钮最小化到托盘" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="点击窗口 ✕ 时最小化而非退出" FontSize="12"
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" x:Name="MinimizeOnCloseChk" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启动后自动连接" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="程序启动时若有活动节点则自动连接" FontSize="12"
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" x:Name="AutoStartCoreChk" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="14,12" Margin="0,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M12,3 L12,13 M12,17 L12,19" Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="24" Height="24"
                              Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="开机自启通过注册表 Run 项实现，路径 HKCU\…\Run，可在此随时关闭或手动在系统设置中移除。"
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource AccentHoverBrush}" LineHeight="20"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Width="110" Height="36" Margin="0,0,10,0" IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource AccentButton}">确定</Button>
            <Button Width="110" Height="36" IsCancel="True">取消</Button>
        </StackPanel>
    </Grid>
</Window>
