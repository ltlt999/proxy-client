<ui:FluentWindow x:Class="ProxyClient.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="关于" Width="420" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- app icon -->
        <Border Grid.Row="0" Width="72" Height="72" CornerRadius="20"
                Background="{StaticResource AccentGradientBrush}" Margin="0,0,0,18">
            <Path Data="M13,3 L6,13 L11,13 L10,21 L17,10 L12,10 Z" Fill="White"
                  Stretch="Uniform" Margin="18"/>
        </Border>

        <!-- title + version -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="ProxyClient" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Text="v1.0.0" FontSize="13"
                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- description -->
        <TextBlock Grid.Row="2" Text="基于 Xray-core 的现代化轻量代理客户端"
                   FontSize="13" Foreground="{StaticResource FgSecondaryBrush}"
                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,18,0,0"/>

        <!-- feature chips -->
        <WrapPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16">
            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="10,4" Margin="4">
                <TextBlock Text="VMess" FontSize="11.5" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentSoftFgBrush}"/>
            </Border>
            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="10,4" Margin="4">
                <TextBlock Text="VLESS" FontSize="11.5" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentSoftFgBrush}"/>
            </Border>
            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="10,4" Margin="4">
                <TextBlock Text="Trojan" FontSize="11.5" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentSoftFgBrush}"/>
            </Border>
            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="10,4" Margin="4">
                <TextBlock Text="Shadowsocks" FontSize="11.5" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentSoftFgBrush}"/>
            </Border>
        </WrapPanel>

        <!-- footer info -->
        <StackPanel Grid.Row="3" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="本地端口：SOCKS5 10808 / HTTP 10809"
                       FontSize="12" Foreground="{StaticResource MutedBrush}" TextAlignment="Center"/>
            <TextBlock Text="关闭按钮可最小化到托盘"
                       FontSize="12" Foreground="{StaticResource MutedBrush}" TextAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ok button -->
        <Button Grid.Row="4" Width="120" Height="36" HorizontalAlignment="Center"
                IsDefault="True" IsCancel="True" Click="Ok_Click"
                Style="{StaticResource AccentButton}">确定</Button>
    </Grid>
</ui:FluentWindow>
