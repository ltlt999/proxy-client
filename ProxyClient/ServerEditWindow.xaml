<ui:FluentWindow x:Class="ProxyClient.ServerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="编辑节点" Width="620" Height="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Style="{StaticResource IconTile}" Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                <Path Data="M18,9 L11,14 L11,27 L25,27 L25,14 Z M18,15 L18,19 M15.5,19 L20.5,19"
                      Stroke="White" StrokeThickness="1.8" StrokeLineJoin="Round"
                      Width="26" Height="26" Stretch="Uniform"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="编辑节点" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                <TextBlock Text="配置服务器连接参数" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel>
                <!-- basic section -->
                <TextBlock Text="基础信息" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="备注" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="协议" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="ProtocolBox" SelectedItem="{Binding Protocol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="地址" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="端口" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="用户ID / 密码" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding UserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- advanced section -->
                <TextBlock Text="高级选项" Style="{StaticResource SectionTitle}"/>
                <ui:CardExpander Header="传输层与 TLS 参数" IsExpanded="True" Margin="0,0,0,16">
                    <StackPanel Margin="0,8,0,0">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="alterId" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding AlterId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="加密方法" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="SecurityBox" IsEditable="True"
                                      Text="{Binding Security, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="传输" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="NetworkBox"
                                      SelectedItem="{Binding Network, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Path" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Host" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SNI" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Sni, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="传输层安全" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="StreamSecurityBox"
                                      SelectedItem="{Binding StreamSecurity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Flow" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Flow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TLS 指纹" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="FingerprintBox" IsEditable="True"
                                      Text="{Binding Fingerprint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Reality 公钥" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding PublicKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ShortId" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding ShortId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <CheckBox Content="跳过证书验证 (allowInsecure)" IsChecked="{Binding AllowInsecure, Mode=TwoWay}"
                                  Margin="120,8,0,0" FontSize="12.5" Foreground="{StaticResource FgSecondaryBrush}"/>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Width="112" Height="36" Margin="0,0,10,0" IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource AccentButton}">确定</Button>
            <Button Width="112" Height="36" IsCancel="True" Style="{StaticResource SecondaryButton}">取消</Button>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
