<Window x:Class="ProxyClient.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Width="580" Height="300"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Grid Width="32" Height="32" Margin="0,0,10,0">
                <Ellipse Width="32" Height="32" Fill="{StaticResource AccentSoftBrush}"/>
                <Path Data="M10,10 L16,16 L10,22 M15,16 L23,16" Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="TitleText" Text="输入" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock x:Name="PromptText" Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,12"
                   Foreground="{DynamicResource FgSecondaryBrush}" FontSize="13"/>

        <Border Grid.Row="2" Background="{StaticResource InputBrush}" CornerRadius="{StaticResource Radius}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <TextBox x:Name="InputBox" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top" KeyDown="InputBox_KeyDown" FontSize="13"
                     Background="Transparent" Foreground="{DynamicResource FgBrush}"
                     CaretBrush="{DynamicResource AccentBrush}" SelectionBrush="{DynamicResource AccentSoftBrush}"
                     BorderThickness="0" Padding="2"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Width="110" Height="36" Margin="0,0,10,0" IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource AccentButton}">确定</Button>
            <Button Width="110" Height="36" IsCancel="True">取消</Button>
        </StackPanel>
    </Grid>
</Window>
