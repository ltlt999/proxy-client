<Window x:Class="ProxyClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ProxyClient"
        Height="740" Width="1040"
        MinHeight="560" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        Closing="Window_Closing" Loaded="Window_Loaded"
        StateChanged="Window_StateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CaptionHeight="0" ResizeBorderThickness="5"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TITLE BAR ===== -->
        <Border Grid.Row="0" Height="40" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8,8,0,0"
                MouseLeftButtonDown="TitleBar_Drag">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Grid Width="26" Height="26" Margin="0,0,10,0">
                        <Ellipse Width="26" Height="26" Fill="{StaticResource AccentSoftBrush}"/>
                        <Path Data="M8,7 L13,13 L8,19 M11,13 L19,13" Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="ProxyClient" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="v1.0" FontSize="11" Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center" Margin="8,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarBtn}" Click="Minimize_Click" ToolTip="最小化" Content="—"/>
                    <Button x:Name="MaxRestoreBtn" Style="{StaticResource TitleBarBtn}" Click="Maximize_Click" ToolTip="最大化" Content="□"/>
                    <Button Style="{StaticResource TitleBarBtn}" Click="Close_Click" ToolTip="关闭" Content="✕">
                        <Button.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MENU ===== -->
        <Menu Grid.Row="1" Padding="8,1">
            <MenuItem Header="服务器(_S)">
                <MenuItem Header="从分享链接添加…" Command="{Binding AddByLinkCommand}"/>
                <MenuItem Header="手动添加…" Command="{Binding AddManualCommand}"/>
                <MenuItem Header="导入订阅…" Command="{Binding ImportSubscriptionCommand}"/>
                <Separator/>
                <MenuItem Header="编辑节点…" Command="{Binding EditCommand}"/>
                <MenuItem Header="删除节点" Command="{Binding DeleteCommand}"/>
            </MenuItem>
            <MenuItem Header="代理(_P)">
                <MenuItem Header="启动" Command="{Binding StartCommand}"/>
                <MenuItem Header="停止" Command="{Binding StopCommand}"/>
                <Separator/>
                <MenuItem Header="切换系统代理" Command="{Binding ToggleProxyCommand}"/>
            </MenuItem>
            <MenuItem Header="测试(_T)">
                <MenuItem Header="测速当前" Command="{Binding TestSelectedCommand}"/>
                <MenuItem Header="测速全部" Command="{Binding TestAllCommand}"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="设置…" Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="关于" Click="About_Click"/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <!-- ===== TOOLBAR ===== -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding StartCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M4,3 L14,9 L4,15 Z" Fill="{StaticResource FgBrush}" Width="10" Height="10"
                              Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="启动" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding StopCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,18,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M4,4 L14,4 L14,14 L4,14 Z" Fill="{StaticResource FgBrush}" Width="10" Height="10"
                              Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="停止" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ToggleProxyCommand}" MinWidth="136" Height="34" Margin="0,0,18,0" Padding="14,7">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M4,2 L14,7 L4,12 M2,7 L16,7" Stroke="White" StrokeThickness="1.8"
                                              Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="开启系统代理" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SystemProxyOn}" Value="True">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M4,2 L14,7 L4,12 M2,7 L16,7" Stroke="White" StrokeThickness="1.8"
                                                      Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="关闭系统代理" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="0,4,18,4"/>

                <TextBlock Text="路由" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource FgSecondaryBrush}" FontSize="13"/>
                <ComboBox ItemsSource="{Binding RoutingModes}" SelectedIndex="{Binding RoutingModeIndex}"
                          MinWidth="180" Height="34" Margin="0,0,18,0"/>

                <Button Command="{Binding ActivateCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M9,2 L11,8 L17,9 L12,13 L14,19 L9,16 L4,19 L6,13 L1,9 L7,8 Z"
                              Fill="{StaticResource FgBrush}" Width="14" Height="14"
                              Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="设为活动" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding TestAllCommand}" Style="{StaticResource ToolbarButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M9,4 A6,6 0 1,1 4,13" Stroke="{StaticResource FgBrush}"
                              StrokeThickness="1.8" Width="14" Height="14" Stretch="Uniform"
                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="测速全部" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="3" Margin="16,12,16,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- server list card -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="12">
                <DataGrid ItemsSource="{Binding Servers}"
                          SelectedItem="{Binding SelectedServer}"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          GridLinesVisibility="None"
                          CanUserAddRows="False" CanUserResizeRows="False" CanUserReorderColumns="False"
                          SelectionMode="Single" AutoGenerateColumns="False"
                          HeadersVisibility="Column" FontSize="13">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="活动" Binding="{Binding IsActive}" IsReadOnly="True" Width="58"
                                                ElementStyle="{StaticResource ActiveCheckBoxStyle}"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="190"/>
                        <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="105"/>
                        <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="*"/>
                        <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="75"/>
                        <DataGridTextColumn Header="传输" Binding="{Binding Network}" Width="68"/>
                        <DataGridTextColumn Header="安全" Binding="{Binding StreamSecurity}" Width="82"/>
                        <DataGridTemplateColumn Header="延迟" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding TestResult, Converter={StaticResource LatencyColorConv}}"
                                            CornerRadius="5" Padding="8,2" HorizontalAlignment="Center" MinWidth="56">
                                        <TextBlock Text="{Binding TestResult}"
                                                   Foreground="{Binding TestResult, Converter={StaticResource LatencyFgConv}}"
                                                   FontSize="12" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- log card -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Padding="16,12,16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="140"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="M4,18 L4,6 L14,6 L20,12 L20,18 Z" Stroke="{StaticResource FgSecondaryBrush}" StrokeThickness="1.8"
                              StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="核心日志" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Row="0" Command="{Binding ClearLogCommand}" HorizontalAlignment="Right"
                                Padding="12,4" Margin="10,0,0,0" FontSize="12" Style="{StaticResource GhostButton}">清空</Button>
                    </StackPanel>
                    <ListBox Grid.Row="1" x:Name="LogList" ItemsSource="{Binding CoreLogs}"
                             FontFamily="Consolas" FontSize="12"
                             Background="{StaticResource InputBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FgSecondaryBrush}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="9" Height="9" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource MutedBrush}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCoreRunning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="PulseOn">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.6" To="1.0" Duration="0:0:0.9"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseOn"/>
                                        </DataTrigger.ExitActions>
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Margin="0,0,16,0" FontSize="12">
                        <Run Text="核心 "/>
                        <Run Text="{Binding CoreState, Mode=OneWay}" Foreground="{StaticResource FgBrush}"/>
                    </TextBlock>
                    <TextBlock Margin="0,0,16,0" FontSize="12">
                        <Run Text="系统代理 "/>
                        <Run Text="{Binding ProxyState, Mode=OneWay}" Foreground="{StaticResource FgBrush}"/>
                    </TextBlock>
                    <TextBlock Margin="0,0,14,0" Foreground="{StaticResource MutedBrush}" FontSize="12">
                        <Run Text="SOCKS "/>
                        <Run Text="{Binding LocalSocks, Mode=OneWay}" Foreground="{StaticResource FgSecondaryBrush}"/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                        <Run Text="HTTP "/>
                        <Run Text="{Binding LocalHttp, Mode=OneWay}" Foreground="{StaticResource FgSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
