<ui:FluentWindow x:Class="ProxyClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:models="clr-namespace:ProxyClient.Models"
        Title="ProxyClient"
        Height="780" Width="1080"
        MinHeight="600" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ExtendsContentIntoTitleBar="True"
        Closing="Window_Closing" Loaded="Window_Loaded">

    <ui:FluentWindow.Resources>
        <!-- ===== big round connect button ===== -->
        <Style x:Key="PowerButton" TargetType="Button">
            <Setter Property="Command" Value="{Binding PowerCommand}"/>
            <Setter Property="Width" Value="84"/>
            <Setter Property="Height" Value="84"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root" RenderTransformOrigin="0.5,0.5" Background="Transparent">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Ellipse x:Name="Ring" Width="78" Height="78" Stroke="#FFD9D9DF" StrokeThickness="2"/>
                            <Ellipse x:Name="DashRing" Width="78" Height="78" Stroke="{StaticResource AccentBrush}"
                                     StrokeThickness="2.5" StrokeDashArray="4 5" StrokeDashCap="Round"
                                     Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Border x:Name="Knob" Width="60" Height="60" CornerRadius="30">
                                <Border.Background>
                                    <SolidColorBrush Color="#FFF0F0F4"/>
                                </Border.Background>
                            </Border>
                            <Path x:Name="PowerIcon" Width="26" Height="26" Stretch="Uniform"
                                  Data="M12,4 L12,12 M7.6,6.4 A7.5,7.5 0 1,0 16.4,6.4"
                                  Stroke="#FF8A8A92" StrokeThickness="2.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.93" ScaleY="0.93"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsCoreRunning}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="SpinRing">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="DashRing"
                                                             Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                             From="0" To="360" Duration="0:0:1.6"
                                                             RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="SpinRing"/>
                                </DataTrigger.ExitActions>
                                <Setter TargetName="DashRing" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter TargetName="Knob" Property="Background" Value="{StaticResource AccentGradientBrush}"/>
                                <Setter TargetName="Knob" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#FF007AFF" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="PowerIcon" Property="Stroke" Value="White"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== iOS style switch (button look, command behavior) ===== -->
        <Style x:Key="IosSwitch" TargetType="Button">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border x:Name="Track" CornerRadius="16">
                                <Border.Background>
                                    <SolidColorBrush Color="#FFE4E4E9"/>
                                </Border.Background>
                            </Border>
                            <Ellipse x:Name="Thumb" Width="26" Height="26" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"
                                     Effect="{StaticResource KnobShadow}" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding SystemProxyOn}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                             To="22" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                            To="#FF34C759" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                            To="#FFE4E4E9" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#FF34C759"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== server list rows ===== -->
        <Style x:Key="ServerRowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RowBd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <SolidColorBrush Color="#00FFFFFF"/>
                            </Border.Background>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="RowBd"
                                                            Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                            To="#FFF2F2F7" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="RowBd"
                                                            Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                            To="#00FFFFFF" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBd" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="ListBoxItem.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.28"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                             From="8" To="0" Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ServerRow" DataType="{x:Type models:ServerItem}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- active check circle -->
                <Grid Grid.Column="0" Width="22" Height="22" Margin="2,0,12,0" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot" Stroke="#FFC7C7CE" StrokeThickness="1.6" Fill="Transparent"/>
                    <Path x:Name="Check" Data="M4.6,6.2 L7.2,8.8 L11.6,3.4" Stroke="White" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Width="16" Height="12" Stretch="Uniform" Visibility="Collapsed"/>
                </Grid>

                <!-- name + details -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Display}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="6"
                                Padding="7,1.5" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Protocol}" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentSoftFgBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Margin="0,3,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}">
                        <Run Text="{Binding Address}"/><Run Text=":"/><Run Text="{Binding Port}"/>
                        <Run Text="  ·  "/><Run Text="{Binding Network}"/>
                        <Run Text="  ·  "/><Run Text="{Binding StreamSecurity}"/>
                    </TextBlock>
                </StackPanel>

                <!-- latency pill -->
                <Border Grid.Column="2" VerticalAlignment="Center" MinWidth="70" Padding="10,3" CornerRadius="11"
                        Background="{Binding TestResult, Converter={StaticResource LatencyColorConv}}">
                    <TextBlock HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding TestResult, Converter={StaticResource LatencyFgConv}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding TestResult}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TestResult}" Value="">
                                        <Setter Property="Text" Value="—"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter TargetName="Dot" Property="Fill" Value="{StaticResource AccentBrush}"/>
                    <Setter TargetName="Dot" Property="Stroke" Value="{StaticResource AccentBrush}"/>
                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TITLE BAR ===== -->
        <ui:TitleBar Grid.Row="0" Title="">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Border Width="24" Height="24" CornerRadius="7" Background="{StaticResource AccentGradientBrush}"
                            Margin="0,0,10,0">
                        <Path Data="M13,3 L6,13 L11,13 L10,21 L17,10 L12,10 Z" Fill="White"
                              Stretch="Uniform" Margin="5"/>
                    </Border>
                    <TextBlock Text="ProxyClient" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="7,1"
                            Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.0" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentSoftFgBrush}"/>
                    </Border>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- ===== MENU ===== -->
        <Menu Grid.Row="1" Padding="10,2">
            <MenuItem Header="服务器(_S)">
                <MenuItem Header="从分享链接添加…" Command="{Binding AddByLinkCommand}"/>
                <MenuItem Header="手动添加…" Command="{Binding AddManualCommand}"/>
                <MenuItem Header="导入订阅…" Command="{Binding ImportSubscriptionCommand}"/>
                <Separator/>
                <MenuItem Header="编辑节点…" Command="{Binding EditCommand}"/>
                <MenuItem Header="删除节点" Command="{Binding DeleteCommand}"/>
            </MenuItem>
            <MenuItem Header="代理(_P)">
                <MenuItem Header="启动" Command="{Binding StartCommand}"/>
                <MenuItem Header="停止" Command="{Binding StopCommand}"/>
                <Separator/>
                <MenuItem Header="切换系统代理" Command="{Binding ToggleProxyCommand}"/>
            </MenuItem>
            <MenuItem Header="测试(_T)">
                <MenuItem Header="测速当前" Command="{Binding TestSelectedCommand}"/>
                <MenuItem Header="测速全部" Command="{Binding TestAllCommand}"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="设置…" Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="关于" Click="About_Click"/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <!-- ===== CONTENT ===== -->
        <Grid Grid.Row="2" Margin="20,10,20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- hero connection card -->
            <Border Grid.Row="0" Style="{StaticResource HeroCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource PowerButton}" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock FontSize="21" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Text" Value="未连接"/>
                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCoreRunning}" Value="True">
                                            <Setter Property="Text" Value="已连接"/>
                                            <Setter Property="Foreground" Value="{StaticResource SuccessFgBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusText}" FontSize="12.5" TextWrapping="Wrap"
                                   Foreground="{StaticResource FgSecondaryBrush}" Margin="0,5,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="路由" FontSize="12.5" Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding RoutingModes}" SelectedIndex="{Binding RoutingModeIndex}"
                                      MinWidth="190" MinHeight="32" FontSize="12.5" VerticalAlignment="Center"/>
                            <TextBlock Text="双击节点设为活动" FontSize="12" Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center" Margin="14,0,0,0" Opacity="0.85"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="系统代理" FontSize="13.5" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding ProxyState}" FontSize="11.5" HorizontalAlignment="Right"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Style="{StaticResource IosSwitch}" Command="{Binding ToggleProxyCommand}"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Border Background="#FFF1F1F4" CornerRadius="10" Padding="10,3" Margin="0,0,8,0">
                                    <TextBlock FontSize="11.5" Foreground="{StaticResource FgSecondaryBrush}">
                                    <Run Text="SOCKS "/><Run Text="{Binding LocalSocks, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#FFF1F1F4" CornerRadius="10" Padding="10,3">
                                <TextBlock FontSize="11.5" Foreground="{StaticResource FgSecondaryBrush}">
                                    <Run Text="HTTP "/><Run Text="{Binding LocalHttp, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- server list card -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="4,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="服务器" FontSize="15" FontWeight="SemiBold"/>
                            <Border Background="#FFF1F1F4" CornerRadius="9" Padding="8,1.5" Margin="8,0,0,0">
                                <TextBlock Text="{Binding Servers.Count, StringFormat={}{0} 个节点}"
                                           FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Command="{Binding TestAllCommand}" Style="{StaticResource GhostButton}" Margin="0,0,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M9,4 A6,6 0 1,1 4,13" Stroke="{StaticResource AccentSoftFgBrush}"
                                          StrokeThickness="1.8" Width="13" Height="13" Stretch="Uniform"
                                          Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="测速全部" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ActivateCommand}" Style="{StaticResource GhostButton}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M9,2 L11,8 L17,9 L12,13 L14,19 L9,16 L4,19 L6,13 L1,9 L7,8 Z"
                                          Stroke="{StaticResource AccentSoftFgBrush}" StrokeThickness="1.4"
                                          Width="13" Height="13" Stretch="Uniform"
                                          Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="设为活动" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource AccentButton}" Padding="16,7" Click="AddMenu_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M9,3 L9,15 M3,9 L15,9" Stroke="White" StrokeThickness="2"
                                          StrokeStartLineCap="Round" Width="12" Height="12" Stretch="Uniform"
                                          Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="添加节点" VerticalAlignment="Center"/>
                                    <Path Data="M2,5 L5,8 L8,5" Stroke="White" StrokeThickness="1.6"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="10" Height="8" Stretch="Uniform"
                                          Margin="6,1,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="从分享链接添加…" Command="{Binding AddByLinkCommand}"/>
                                        <MenuItem Header="手动添加…" Command="{Binding AddManualCommand}"/>
                                        <MenuItem Header="导入订阅…" Command="{Binding ImportSubscriptionCommand}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <ListBox x:Name="ServerList"
                                 ItemsSource="{Binding Servers}"
                                 SelectedItem="{Binding SelectedServer}"
                                 ItemTemplate="{StaticResource ServerRow}"
                                 ItemContainerStyle="{StaticResource ServerRowStyle}"
                                 MouseDoubleClick="ServerList_MouseDoubleClick"
                                 PreviewMouseRightButtonDown="ServerList_PreviewMouseRightButtonDown"
                                 Background="Transparent" BorderThickness="0"
                                 VirtualizingStackPanel.IsVirtualizing="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="设为活动" Command="{Binding ActivateCommand}"/>
                                    <MenuItem Header="测速当前" Command="{Binding TestSelectedCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="编辑节点…" Command="{Binding EditCommand}"/>
                                    <MenuItem Header="删除节点" Command="{Binding DeleteCommand}"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                        <TextBlock Text="还没有服务器，点击右上角「添加节点」开始" FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Servers.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <!-- log card -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="130"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,8">
                        <Path Data="M4,18 L4,6 L14,6 L20,12 L20,18 Z" Stroke="{StaticResource MutedBrush}" StrokeThickness="1.8"
                              StrokeLineJoin="Round" Width="15" Height="15" Stretch="Uniform" Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="核心日志" FontWeight="SemiBold" FontSize="13.5"
                                   Foreground="{StaticResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                        <Button Command="{Binding ClearLogCommand}" HorizontalAlignment="Right"
                                Margin="10,0,0,0" Style="{StaticResource GhostButton}">清空</Button>
                    </StackPanel>
                    <ListBox Grid.Row="1" x:Name="LogList" ItemsSource="{Binding CoreLogs}"
                             FontFamily="Consolas" FontSize="12" Foreground="#FF34343C"
                             Background="{StaticResource InputFillBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,9">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Margin="0,0,7,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FFC7C7CE"/>
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCoreRunning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="PulseOn">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.55" To="1.0" Duration="0:0:0.9"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseOn"/>
                                        </DataTrigger.ExitActions>
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="12" Foreground="{StaticResource FgSecondaryBrush}">
                        <Run Text="核心 "/><Run Text="{Binding CoreState, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Border Width="1" Height="12" Background="{StaticResource BorderLightBrush}" Margin="12,0"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource FgSecondaryBrush}">
                        <Run Text="系统代理 "/><Run Text="{Binding ProxyState, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource MutedBrush}">
                    <Run Text="SOCKS "/><Run Text="{Binding LocalSocks, Mode=OneWay}"/>
                    <Run Text="   HTTP "/><Run Text="{Binding LocalHttp, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
